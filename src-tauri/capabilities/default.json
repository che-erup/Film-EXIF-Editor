{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "메인 창의 기본 권한: 파일 선택 대화상자 + ExifTool 사이드카 실행.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/exiftool",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
