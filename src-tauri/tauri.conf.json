{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Film EXIF Tool",
  "version": "0.2.0",
  "identifier": "com.filmexif.tool",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "필름 EXIF 수정 툴",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 640,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/exiftool"],
    "resources": {
      "binaries/lib/": "exiftool-lib"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
